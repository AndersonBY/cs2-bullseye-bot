<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>BotAimImprover</RootNamespace>
    <AssemblyName>BotAimImprover</AssemblyName>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <ImplicitUsings>enable</ImplicitUsings>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <Version>2.1.4</Version>
    <AssemblyVersion>2.1.4.0</AssemblyVersion>
    <FileVersion>2.1.4.0</FileVersion>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="CounterStrikeSharp.API" Version="1.0.371" />
    <Reference Include="RayTraceApi">
      <HintPath>libs/RayTraceApi.dll</HintPath>
      <Private>false</Private>
    </Reference>
  </ItemGroup>

  <Target Name="EnsureRayTraceDependency" BeforeTargets="ResolveReferences">
    <Error Condition="!Exists('libs/RayTraceApi.dll')" Text="RayTraceApi.dll is missing. Run scripts/fetch-raytrace.sh before building." />
  </Target>

</Project>
